# External Codex API relay. Prefer these variables for your setup.
CODEX_API_KEY=your-relay-key
CODEX_API_BASE_URL=https://your-codex-api-relay.example.com/v1
CODEX_API_MODEL=gpt-5.5

# Use "responses" if the relay is compatible with /v1/responses.
# Use "chat_completions" if the relay is compatible with /v1/chat/completions.
CODEX_API_MODE=responses

# Optional. Override when your relay endpoint path is not the standard one.
# CODEX_API_PATH=/responses
# CODEX_API_PATH=/chat/completions

# Optional fallback for direct OpenAI-compatible setups.
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.5
# Optional LAN wiki retrieval. Keep disabled until the wiki server exposes read-only search APIs.
WIKI_ENABLED=false
WIKI_BASE_URL=http://10.10.124.11:8787
WIKI_SEARCH_PATH=/api/wiki/search
WIKI_DOC_PATH=/api/wiki/doc
WIKI_CHUNK_PATH=/api/wiki/chunk
WIKI_INDEX_DOC_ID=wiki/index.md
WIKI_MAX_SEARCH_RESULTS=12
WIKI_MAX_EXPANDED_CHUNKS=4
WIKI_TOKEN=
WIKI_TIMEOUT_MS=5000
WIKI_CACHE_TTL_MS=300000
# Set true only if every discussion turn should query the wiki. Default behavior searches only when context needs existing knowledge.
WIKI_AUTO_SEARCH_ALWAYS=false
